    <!-- Main Workspace (Editor + Terminal Panels) -->
    <div class="flex-1 grid grid-cols-1 lg:grid-cols-2 overflow-hidden min-h-0">
      
      <!-- Interactive Code Editor Panel -->
      <section id="panel-editor" class="hidden lg:flex flex-col border-b lg:border-b-0 lg:border-r border-slate-800 overflow-hidden h-full">
        <div class="p-4 border-b border-slate-800 bg-[#0d111a]/20 flex items-center justify-between">
          <div class="flex items-center space-x-2">
            <i data-lucide="code-2" class="w-4 h-4 text-indigo-400"></i>
            <span id="editor-filename" class="text-sm font-semibold font-mono text-slate-300">Loading Workspace...</span>
            <span id="editor-badge" class="text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded bg-slate-800 text-slate-400 font-mono">CODE</span>
