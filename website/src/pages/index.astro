<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CLI Projects - Web Playground</title>
  <!-- Load Monaco Editor AMD Loader -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs/loader.min.js" is:inline></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#090d16] text-[#e6edf3] font-['Plus_Jakarta_Sans',sans-serif] h-full flex flex-col antialiased select-none">

  <!-- Header -->
  <header class="border-b border-slate-800 bg-[#0d111a]/95 backdrop-blur px-6 py-4 flex items-center justify-between z-50 shrink-0">
    <div class="flex items-center space-x-3">
      <div class="p-2 bg-indigo-600/10 rounded-lg border border-indigo-500/30 shadow-[0_0_15px_rgba(99,102,241,0.15)]">
        <i data-lucide="terminal" class="w-6 h-6 text-indigo-400"></i>
      </div>
      <div>
        <h1 class="text-lg font-bold tracking-tight bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
          CLI Sandbox
        </h1>
        <p class="text-xs text-slate-500 font-medium">Interactive Web-Native Terminal & Compiler</p>
      </div>
    </div>
    
    <div class="flex items-center space-x-4">
      <a href="https://github.com/godwin-binoy/cli-beginer-projects" target="_blank" class="flex items-center space-x-2 text-xs text-slate-400 hover:text-white bg-slate-900/60 hover:bg-slate-800 border border-slate-800 px-3 py-1.5 rounded-lg transition-all duration-200">
        <i data-lucide="github" class="w-4 h-4"></i>
        <span class="font-medium font-mono">Repository</span>
      </a>
    </div>
  </header>

  <!-- Mobile Tab Navigation Bar (Visible only on Mobile) -->
  <div class="lg:hidden flex border-b border-slate-800 bg-[#0d111a] shrink-0">
    <button id="tab-btn-explorer" class="flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5">
      <i data-lucide="folder" class="w-4 h-4"></i> Explorer
    </button>
    <button id="tab-btn-editor" class="flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5">
      <i data-lucide="code-2" class="w-4 h-4"></i> Editor
    </button>
    <button id="tab-btn-terminal" class="flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5">
      <i data-lucide="terminal" class="w-4 h-4"></i> Terminal
    </button>
  </div>

  <!-- Workspace Shell -->
  <div class="flex-1 flex flex-col lg:flex-row overflow-hidden min-h-0 relative">
    
    <!-- Redesigned Repository Map / File Explorer -->
    <aside id="sidebar-explorer" class="w-full lg:w-72 border-r border-slate-800 bg-[#0d111a]/40 flex flex-col h-full lg:flex overflow-y-auto">
      <div class="p-4 border-b border-slate-800 flex items-center justify-between">
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider font-mono">Repository Map</span>
        <span class="text-xs bg-slate-800 text-slate-400 px-2 py-0.5 rounded-full font-mono">{projectsList.length} files</span>
      </div>
      <div class="p-3 border-b border-slate-800 bg-[#0c1018]">
        <input type="text" id="file-search" placeholder="Search files..." class="w-full bg-slate-950 text-slate-300 border border-slate-800 rounded px-2.5 py-1.5 text-xs outline-none focus:border-indigo-500 transition-colors" />
      </div>
