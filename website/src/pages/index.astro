  <!-- Load client libraries -->
  <script>
    import { WTerm } from "@wterm/dom";
    import "@wterm/dom/css";
    import { createIcons, Terminal, Code2, Folder, FolderOpen, RefreshCw, Play, Trash2, Smartphone, Monitor, ChevronDown, FileCode, Coffee, FileText, Github, Download, X } from "lucide";

    // Initialize UI Icons
    createIcons({
      icons: {
        Terminal,
        Code2,
        Folder,
        FolderOpen,
        RefreshCw,
        Play,
        Trash2,
        Smartphone,
        Monitor,
        ChevronDown,
        FileCode,
        Coffee,
        FileText,
        Github,
        Download,
        X
      }
    });

    const PROJECTS = JSON.parse(document.getElementById("projects-data").getAttribute("data-projects"));
    let activeProjectId = PROJECTS.length > 0 ? PROJECTS[0].id : null;
    let editorInstance = null;
    const modifiedCodes = {};
    const collapsedFolders = {};

    PROJECTS.forEach(p => {
      modifiedCodes[p.id] = p.code;
    });

    // Mobile tabs selectors
    const tabExplorer = document.getElementById("tab-btn-explorer");
    const tabEditor = document.getElementById("tab-btn-editor");
    const tabTerminal = document.getElementById("tab-btn-terminal");

    const sidebarExplorer = document.getElementById("sidebar-explorer");
    const mainWorkspace = document.getElementById("main-workspace");
    const panelEditor = document.getElementById("panel-editor");
    const panelTerminal = document.getElementById("panel-terminal");

    function switchMobileTab(tab) {
      if (window.innerWidth >= 1024) return;

      // Hide all panels on mobile
      sidebarExplorer.classList.add("hidden");
      sidebarExplorer.classList.remove("flex");

      mainWorkspace.classList.add("hidden");
      mainWorkspace.classList.remove("grid");

      panelEditor.classList.add("hidden");
      panelEditor.classList.remove("flex");

      panelTerminal.classList.add("hidden");
      panelTerminal.classList.remove("flex");

      // Reset tab button styling
      tabExplorer.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5";
      tabEditor.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5";
      tabTerminal.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5";

      if (tab === "explorer") {
        sidebarExplorer.classList.remove("hidden");
        sidebarExplorer.classList.add("flex");
        tabExplorer.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5";
      } else if (tab === "editor") {
        mainWorkspace.classList.remove("hidden");
        mainWorkspace.classList.add("grid");
        panelEditor.classList.remove("hidden");
        panelEditor.classList.add("flex");
        tabEditor.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5";
        if (editorInstance) {
          setTimeout(() => editorInstance.layout(), 50);
        }
      } else if (tab === "terminal") {
        mainWorkspace.classList.remove("hidden");
        mainWorkspace.classList.add("grid");
        panelTerminal.classList.remove("hidden");
        panelTerminal.classList.add("flex");
        tabTerminal.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5";
      }
    }

    tabExplorer.addEventListener("click", () => switchMobileTab("explorer"));
    tabEditor.addEventListener("click", () => switchMobileTab("editor"));
    tabTerminal.addEventListener("click", () => switchMobileTab("terminal"));

    // Set initial display configuration
    if (window.innerWidth < 1024) {
      switchMobileTab("explorer");
    } else {
      sidebarExplorer.classList.remove("hidden");
      sidebarExplorer.classList.add("flex");
      mainWorkspace.classList.remove("hidden");
      mainWorkspace.classList.add("grid");
      panelEditor.classList.remove("hidden");
      panelEditor.classList.add("flex");
      panelTerminal.classList.remove("hidden");
      panelTerminal.classList.add("flex");
    }

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) {
        sidebarExplorer.classList.remove("hidden");
        sidebarExplorer.classList.add("flex");
        
        mainWorkspace.classList.remove("hidden");
        mainWorkspace.classList.add("grid");
        
        panelEditor.classList.remove("hidden");
        panelEditor.classList.add("flex");
        
        panelTerminal.classList.remove("hidden");
        panelTerminal.classList.add("flex");
      } else {
        const activeTab = tabEditor.classList.contains("text-white") ? "editor" : 
                          (tabTerminal.classList.contains("text-white") ? "terminal" : "explorer");
        switchMobileTab(activeTab);
      }
    });

    // Custom Regex-Based Markdown Previewer
    function parseMarkdown(md) {
      if (!md || md.trim().length === 0) {
        return `<div class="p-4 text-center text-slate-500 italic border border-slate-800/40 rounded bg-[#090d16]">No README.md found in this project folder.</div>`;
      }
      
      let html = md
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");

      // Headers parsing
      html = html.replace(/^### (.*$)/gim, '<h3 class="text-sm font-bold text-slate-100 mt-4 mb-1">$1</h3>');
      html = html.replace(/^## (.*$)/gim, '<h2 class="text-base font-bold text-slate-100 border-b border-slate-800 pb-1 mt-5 mb-2">$1</h2>');
      html = html.replace(/^# (.*$)/gim, '<h1 class="text-lg font-extrabold text-white mt-6 mb-3">$1</h1>');

      // Font weights
      html = html.replace(/\*\*\*(.*)\*\*\*/g, '<strong><em>$1</em></strong>');
      html = html.replace(/\*\*(.*)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/\*(.*)\*/g, '<em>$1</em>');
      html = html.replace(/__(.*)__/g, '<strong>$1</strong>');
      html = html.replace(/_(.*)_/g, '<em>$1</em>');

      // Inline code snippets
      html = html.replace(/`([^`]+)`/g, '<code class="bg-slate-950 px-1.5 py-0.5 rounded text-indigo-400 font-mono text-xs border border-slate-800">$1</code>');

      // Preformatted multi-line block code
      html = html.replace(/```(.*?)\n([\s\S]*?)```/gm, '<pre class="bg-slate-950 p-4 rounded-lg my-3 border border-slate-800/80 overflow-x-auto text-xs font-mono text-slate-300">$2</pre>');

      // Bullet Lists & Numbers
      html = html.replace(/^\s*-\s+(.*$)/gim, '<li class="ml-4 list-disc text-slate-300 my-1">$1</li>');
      html = html.replace(/^\s*\*\s+(.*$)/gim, '<li class="ml-4 list-disc text-slate-300 my-1">$1</li>');
      html = html.replace(/^\s*\d+\.\s+(.*$)/gim, '<li class="ml-4 list-decimal text-slate-300 my-1">$1</li>');

      // Split paragraphs by spacing
      html = html.split(/\n{2,}/g).map(p => {
        const trimmed = p.trim();
        if (trimmed.startsWith('<h') || trimmed.startsWith('<li') || trimmed.startsWith('<pre') || trimmed.startsWith('<ul') || trimmed.startsWith('<ol')) {
          return p;
        }
        return `<p class="my-2.5 text-xs text-slate-400 leading-relaxed">${p.replace(/\n/g, "<br>")}</p>`;
      }).join('\n');

      return html;
    }

