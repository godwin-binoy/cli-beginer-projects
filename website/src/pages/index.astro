---
import fs from 'fs';
import path from 'path';
import '../styles/global.css';

const rootDir = path.resolve(process.cwd(), '..');

function getProjects() {
  const projects = [];
  if (!fs.existsSync(rootDir)) {
    return [];
  }
  
  const items = fs.readdirSync(rootDir);
  const ignoreList = ['.git', '.github', 'website', 'node_modules', '.astro'];
  
  for (const item of items) {
    if (ignoreList.includes(item)) continue;
    const itemPath = path.join(rootDir, item);
    const stat = fs.statSync(itemPath);
    
    if (stat.isDirectory()) {
      const files = fs.readdirSync(itemPath);
      for (const file of files) {
        const filePath = path.join(itemPath, file);
        const fileStat = fs.statSync(filePath);
        if (fileStat.isFile()) {
          const ext = path.extname(file).toLowerCase();
          let lang = '';
          let badge = '';
          if (ext === '.py') { lang = 'python'; badge = 'Python'; }
          else if (ext === '.c') { lang = 'c'; badge = 'C'; }
          else if (ext === '.java') { lang = 'java'; badge = 'Java'; }
          else continue;
          
          const code = fs.readFileSync(filePath, 'utf-8');
          const id = `${item.toLowerCase()}-${file.toLowerCase().replace(/[^a-z0-9]/g, '-')}`;
          const title = item.replace(/-/g, ' ');
          const description = `Interactive ${badge} program for ${title.toLowerCase()}.`;
          
          projects.push({
            id,
            title: `${title} (${file})`,
            folder: item,
            filename: file,
            lang,
            badge,
            file: `${item}/${file}`,
            description,
            code
          });
        }
      }
    }
  }
  return projects.sort((a, b) => a.title.localeCompare(b.title));
}

const projectsList = getProjects();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CLI Projects - WebAssembly Playground</title>
  <script is:inline src="https://cdn.jsdelivr.net/pyodide/v0.26.4/full/pyodide.js"></script>
  <!-- Load Monaco Editor -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs/loader.min.js"></script>
  <!-- Load Lucide Icons -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.400.0/dist/umd/lucide.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#090d16] text-[#e6edf3] font-['Plus_Jakarta_Sans',sans-serif] min-h-screen flex flex-col antialiased select-none">

  <!-- Interactive Header -->
  <header class="border-b border-slate-800 bg-[#0d111a]/90 backdrop-blur px-6 py-4 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center space-x-3">
      <div class="p-2 bg-indigo-600/10 rounded-lg border border-indigo-500/30 shadow-[0_0_15px_rgba(99,102,241,0.15)]">
        <i data-lucide="terminal" class="w-6 h-6 text-indigo-400"></i>
      </div>
      <div>
        <h1 class="text-lg font-bold tracking-tight bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
          CLI Playground
        </h1>
        <p class="text-xs text-slate-500 font-medium">Interactive WebAssembly sandbox</p>
      </div>
    </div>
    
    <div class="flex items-center space-x-4">
      <div class="flex items-center space-x-2 bg-slate-900/80 border border-slate-800 px-3 py-1.5 rounded-full text-xs">
        <span class="relative flex h-2.5 w-2.5">
          <span id="runtime-status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span id="runtime-status-dot" class="relative inline-flex rounded-full h-2.5 w-2.5 bg-amber-500"></span>
        </span>
        <span id="runtime-status-text" class="text-slate-400 font-medium font-mono">WASM Engine: Standby</span>
      </div>

      <a href="https://github.com/godwin-binoy/cli-beginer-projects" target="_blank" class="flex items-center space-x-2 text-xs text-slate-400 hover:text-white bg-slate-900/60 hover:bg-slate-800 border border-slate-800 px-3 py-1.5 rounded-lg transition-all duration-200">
        <i data-lucide="github" class="w-4 h-4"></i>
        <span class="font-medium font-mono">Repository</span>
      </a>
    </div>
  </header>

  <!-- Responsive Layout container -->
  <div class="flex-1 flex flex-col md:flex-row overflow-hidden">
    
    <!-- Left Sidebar - Desktop only -->
    <aside class="hidden md:flex w-80 border-r border-slate-800 bg-[#0d111a]/40 flex-col overflow-y-auto">
      <div class="p-4 border-b border-slate-800 flex items-center justify-between">
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider font-mono">Dynamic Project Index</span>
        <span class="text-xs bg-slate-800 text-slate-400 px-2 py-0.5 rounded-full font-mono">{projectsList.length} Files</span>
      </div>
      <div id="project-list" class="flex-1 p-3 space-y-1">
        <!-- Injected dynamically via client script -->
      </div>
    </aside>

    <!-- Main Working Layout -->
    <main class="flex-1 flex flex-col overflow-hidden bg-[#090d16]">
      
      <!-- Responsive Mobile selector bar -->
      <div class="md:hidden p-4 border-b border-slate-800 bg-[#0d111a]/60 flex flex-col gap-3">
        <div>
          <label for="mobile-project-selector" class="block text-xs font-semibold uppercase text-slate-500 tracking-wider mb-2">Select Project</label>
          <select id="mobile-project-selector" class="w-full bg-slate-950 text-slate-200 border border-slate-800 rounded-lg px-3 py-2 text-sm outline-none focus:border-indigo-500">
            <!-- Options dynamically added -->
          </select>
        </div>
      </div>

      <!-- IDE Editor and Console split pane -->
      <div class="flex-1 grid grid-cols-1 lg:grid-cols-2 overflow-hidden min-h-0">
        
        <!-- Interactive Code Editor container -->
        <section class="flex flex-col border-b lg:border-b-0 lg:border-r border-slate-800 overflow-hidden min-h-[350px] lg:min-h-0 w-full">
          <div class="p-4 border-b border-slate-800 bg-[#0d111a]/20 flex items-center justify-between">
            <div class="flex items-center space-x-2">
              <i data-lucide="code-2" class="w-4 h-4 text-indigo-400"></i>
              <span id="editor-filename" class="text-sm font-semibold font-mono text-slate-300">Loading IDE...</span>
              <span id="editor-badge" class="text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 font-mono">CODE</span>
            </div>
            
            <button id="btn-reset" class="flex items-center space-x-1.5 text-xs text-slate-400 hover:text-white bg-slate-900 border border-slate-800 hover:border-slate-700 px-3 py-1.5 rounded-lg transition duration-200">
              <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i>
              <span class="font-medium">Reset Default</span>
            </button>
          </div>
          
          <!-- Full Featured Monaco IDE Integration container -->
          <div class="flex-1 p-4 bg-[#0d111a]/10 relative overflow-hidden min-h-0">
            <div id="editor-container" class="w-full h-full rounded-xl border border-slate-800/80 overflow-hidden"></div>
          </div>
          
          <!-- Editor Bottom Toolbar -->
          <div class="p-4 border-t border-slate-800 bg-[#0d111a]/25 flex items-center justify-between flex-wrap gap-2">
            <p class="text-xs text-slate-500 font-medium">Full Monaco IDE. Auto-saves changes in virtual memory.</p>
            <button id="btn-run" class="flex items-center space-x-2 bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white font-semibold text-sm px-5 py-2.5 rounded-lg shadow-[0_0_20px_rgba(16,185,129,0.15)] hover:shadow-[0_0_25px_rgba(16,185,129,0.25)] transition-all duration-200 group cursor-pointer">
              <i data-lucide="play" class="w-4 h-4 text-emerald-100 group-hover:scale-110 transition duration-150"></i>
              <span id="run-text">Run Program</span>
            </button>
          </div>
        </section>

        <!-- Simulated Terminal Simulator -->
        <section class="flex flex-col overflow-hidden min-h-[250px] lg:min-h-0 bg-[#03060a]">
          <div class="p-4 border-b border-slate-800 bg-[#0d111a]/20 flex items-center justify-between">
            <div class="flex items-center space-x-2">
              <i data-lucide="terminal" class="w-4 h-4 text-indigo-400"></i>
              <span class="text-sm font-semibold font-mono text-slate-300">Terminal Sandbox Output</span>
            </div>
            <button id="btn-clear" class="text-xs text-slate-500 hover:text-slate-300 transition duration-150 cursor-pointer">Clear Output</button>
          </div>

          <div class="flex-1 p-6 overflow-hidden flex flex-col min-h-0 relative">
            <div id="terminal-body" class="flex-1 overflow-y-auto font-mono text-sm leading-6 pr-2 scrollbar-thin scrollbar-thumb-slate-800 text-slate-300 select-text">
              <!-- Terminal logs feed here -->
            </div>
          </div>

          <!-- Virtual Metrics Deck -->
          <div class="border-t border-slate-800 bg-[#070b12] px-6 py-4 grid grid-cols-2 sm:grid-cols-4 gap-4 text-xs font-mono">
            <div class="space-y-1">
              <span class="text-slate-500 block">CONTAINER CORE</span>
              <span id="stat-vm-type" class="text-slate-300 font-semibold">WebAssembly Sandbox</span>
            </div>
            <div class="space-y-1">
              <span class="text-slate-500 block">LOCAL STATE</span>
              <span id="stat-state" class="text-emerald-400 font-semibold flex items-center">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse mr-1.5"></span> Engine Standby
              </span>
            </div>
            <div class="space-y-1">
              <span class="text-slate-500 block">SOURCE SIZE</span>
              <span id="stat-size" class="text-slate-300 font-semibold">0.0 KB</span>
            </div>
            <div class="space-y-1">
              <span class="text-slate-500 block">SYSTEM LOAD</span>
              <span id="stat-cpu" class="text-slate-300 font-semibold">0.1% CPU</span>
            </div>
          </div>
        </section>

      </div>
    </main>
  </div>

  <script is:inline define:vars={{ projectsList }}>
    const PROJECTS = projectsList;
    
    let activeProjectId = PROJECTS.length > 0 ? PROJECTS[0].id : null;
    let isRunning = false;
    let pyodideInstance = null;
    let editorInstance = null;
    const modifiedCodes = {};

    PROJECTS.forEach(p => {
      modifiedCodes[p.id] = p.code;
    });

    const projectListEl = document.getElementById('project-list');
    const mobileSelectorEl = document.getElementById('mobile-project-selector');
    const filenameEl = document.getElementById('editor-filename');
    const badgeEl = document.getElementById('editor-badge');
    const terminalEl = document.getElementById('terminal-body');
    const btnRun = document.getElementById('btn-run');
    const runText = document.getElementById('run-text');
    const btnReset = document.getElementById('btn-reset');
    const btnClear = document.getElementById('btn-clear');
    
    const statusDot = document.getElementById('runtime-status-dot');
    const statusPulse = document.getElementById('runtime-status-pulse');
    const statusText = document.getElementById('runtime-status-text');

    const statVmType = document.getElementById('stat-vm-type');
    const statState = document.getElementById('stat-state');
    const statSize = document.getElementById('stat-size');
    const statCpu = document.getElementById('stat-cpu');

    require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs' } });

    function renderSidebar() {
      if (!projectListEl) return;
      projectListEl.innerHTML = PROJECTS.map(project => {
        const isActive = project.id === activeProjectId;
        return `
          <button data-id="${project.id}" class="w-full text-left px-3.5 py-3 rounded-lg flex flex-col space-y-1 transition-all duration-150 cursor-pointer ${
            isActive 
              ? 'bg-indigo-600/15 border border-indigo-500/30 text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] font-bold' 
              : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/40 border border-transparent font-medium'
          }">
            <div class="flex items-center justify-between w-full">
              <span class="text-xs font-mono tracking-tight truncate max-w-[150px]">${project.title}</span>
              <span class="text-[9px] font-mono px-1.5 py-0.5 rounded bg-[#0a0f1d] text-slate-500 border border-slate-800/60 uppercase font-semibold">${project.badge}</span>
            </div>
            <span class="text-[11px] leading-relaxed text-slate-500 truncate w-full font-sans">${project.description}</span>
          </button>
        `;
      }).join('');

      projectListEl.querySelectorAll('button[data-id]').forEach(btn => {
        btn.addEventListener('click', () => {
          switchProject(btn.getAttribute('data-id'));
        });
      });
    }

    function renderMobileSelector() {
      if (!mobileSelectorEl) return;
      mobileSelectorEl.innerHTML = PROJECTS.map(project => {
        return `<option value="${project.id}" ${project.id === activeProjectId ? 'selected' : ''}>${project.title} [${project.badge}]</option>`;
      }).join('');
    }

    if (mobileSelectorEl) {
      mobileSelectorEl.addEventListener('change', (e) => {
        switchProject(e.target.value);
      });
    }

    function switchProject(id) {
      if (isRunning) {
        writeToTerminal("\n[System Alert] A program is currently running. Please let it finish or wait.\n", "error");
        return;
      }
      
      if (editorInstance && activeProjectId) {
        modifiedCodes[activeProjectId] = editorInstance.getValue();
      }

      activeProjectId = id;
      const project = PROJECTS.find(p => p.id === id);
      if (!project) return;

      filenameEl.textContent = `File: ${project.file}`;
      badgeEl.textContent = project.badge;
      
      const targetCode = modifiedCodes[id];
      const codeSizeKb = (new Blob([targetCode]).size / 1024).toFixed(2);
      statSize.textContent = `${codeSizeKb} KB`;

      if (editorInstance) {
        editorInstance.setValue(targetCode);
        const mappedLang = project.lang === 'c' ? 'cpp' : project.lang;
        monaco.editor.setModelLanguage(editorInstance.getModel(), mappedLang);
      } else {
        require(['vs/editor/editor.main'], function () {
          const mappedLang = project.lang === 'c' ? 'cpp' : project.lang;
          editorInstance = monaco.editor.create(document.getElementById('editor-container'), {
            value: targetCode,
            language: mappedLang,
            theme: 'vs-dark',
            automaticLayout: true,
            fontFamily: 'Fira Code, monospace',
            fontSize: 14,
            minimap: { enabled: false },
            scrollbar: {
              vertical: 'visible',
              horizontal: 'visible'
            }
          });
        });
      }

      statVmType.textContent = project.lang === "python" ? "Pyodide WASM" : "WASM Offline View";
      
      renderSidebar();
      renderMobileSelector();
      clearTerminal();
      writeToTerminal(`[Ready] System workspace loaded for: ${project.filename}.\nPress "Run Program" to execute.\n`, "system");
    }

    function writeToTerminal(text, type = "default") {
      const span = document.createElement('span');
      if (type === "error") {
        span.className = "text-rose-400 font-mono block whitespace-pre-wrap";
      } else if (type === "system") {
        span.className = "text-indigo-400 font-mono font-semibold block whitespace-pre-wrap";
      } else {
        span.className = "text-slate-200 font-mono block whitespace-pre-wrap";
      }
      span.textContent = text;
      terminalEl.appendChild(span);
      terminalEl.scrollTop = terminalEl.scrollHeight;
    }

    function clearTerminal() {
      terminalEl.innerHTML = "";
    }

    btnClear.addEventListener('click', clearTerminal);

    function updateEngineStatus(state) {
      if (state === "starting") {
        statusDot.className = "relative inline-flex rounded-full h-2.5 w-2.5 bg-amber-500";
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75";
        statusText.textContent = "WASM Engine: Starting...";
        statState.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-amber-400 animate-pulse mr-1.5"></span> Starting';
      } else if (state === "active") {
        statusDot.className = "relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500";
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75";
        statusText.textContent = "WASM Engine: Active";
        statState.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-emerald-400 mr-1.5"></span> Active';
        statCpu.textContent = "0.1% CPU";
      } else if (state === "executing") {
        statState.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-indigo-500 animate-pulse mr-1.5"></span> Executing';
        statCpu.textContent = "35.2% CPU";
      } else if (state === "offline") {
        statusDot.className = "relative inline-flex rounded-full h-2.5 w-2.5 bg-rose-500";
        statusPulse.className = "";
        statusText.textContent = "WASM Engine: Offline";
        statState.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-rose-500 mr-1.5"></span> Failed';
        statCpu.textContent = "0.0% CPU";
      }
    }

    async function initPyodide() {
      if (pyodideInstance) return pyodideInstance;
      
      updateEngineStatus("starting");
      writeToTerminal("Loading Pyodide browser-runtime core...\n", "system");
      
      try {
        pyodideInstance = await loadPyodide({
          indexURL: "https://cdn.jsdelivr.net/pyodide/v0.26.4/full/"
        });
        
        pyodideInstance.setStdout({
          write: (text) => {
            writeToTerminal(text);
            return text.length;
          }
        });

        pyodideInstance.setStderr({
          write: (text) => {
            writeToTerminal(text, "error");
            return text.length;
          }
        });

        await pyodideInstance.runPythonAsync(`
import builtins
import sys
import js

def web_input(prompt_msg=""):
    if prompt_msg:
        sys.stdout.write(prompt_msg)
        sys.stdout.flush()
    val = js.prompt(prompt_msg or "CLI Input Required:")
    if val is None:
        val = "exit"
    else:
        sys.stdout.write(val + "\\n")
        sys.stdout.flush()
    return val

builtins.input = web_input
`);

        updateEngineStatus("active");
        writeToTerminal("WASM standard runtime initialized successfully.\n\n", "system");
        return pyodideInstance;
      } catch (err) {
        updateEngineStatus("offline");
        writeToTerminal(`Failed to initialize WebAssembly sandbox: ${err.message}\n`, "error");
        throw err;
      }
    }

    btnRun.addEventListener('click', async () => {
      if (isRunning) return;

      const currentProject = PROJECTS.find(p => p.id === activeProjectId);
      if (!currentProject) return;

      const currentCode = editorInstance ? editorInstance.getValue() : modifiedCodes[activeProjectId];

      isRunning = true;
      btnRun.disabled = true;
      btnRun.classList.add('opacity-75', 'cursor-not-allowed');
      runText.textContent = "Executing...";

      try {
        if (currentProject.lang !== "python") {
          clearTerminal();
          writeToTerminal(`[Compilation Notice] Direct browser runtime is disabled for compiled code (${currentProject.badge}).\n\n`, "system");
          writeToTerminal(`To compile and run this code locally, run:\n`, "default");
          if (currentProject.lang === "c") {
            writeToTerminal(`  gcc ${currentProject.filename} -o app && ./app\n\n`, "default");
          } else if (currentProject.lang === "java") {
            writeToTerminal(`  javac ${currentProject.filename} && java ${currentProject.filename.replace('.java', '')}\n\n`, "default");
          }
          writeToTerminal(`Feel free to edit the source code inside this IDE window. Your changes are automatically stored in-memory!\n`, "system");
          return;
        }

        clearTerminal();
        writeToTerminal(`[Initializing Execution Environment]\n`, "system");
        const py = await initPyodide();
        
        updateEngineStatus("executing");
        await py.runPythonAsync(currentCode);
        writeToTerminal("\n[Program completed execution]\n", "system");
      } catch (err) {
        const errMsg = err.message || String(err);
        if (errMsg.includes("SystemExit")) {
          writeToTerminal("\n[Program exited successfully]\n", "system");
        } else {
          writeToTerminal(`\n[Runtime Exception]\n${errMsg}\n`, "error");
        }
      } finally {
        isRunning = false;
        btnRun.disabled = false;
        btnRun.classList.remove('opacity-75', 'cursor-not-allowed');
        runText.textContent = "Run Program";
        updateEngineStatus("active");
      }
    });

    btnReset.addEventListener('click', () => {
      if (confirm("Reset editor to default repository version? All unsaved modifications will be lost.")) {
        const project = PROJECTS.find(p => p.id === activeProjectId);
        if (project) {
          modifiedCodes[activeProjectId] = project.code;
          if (editorInstance) {
            editorInstance.setValue(project.code);
          }
          const codeSizeKb = (new Blob([project.code]).size / 1024).toFixed(2);
          statSize.textContent = `${codeSizeKb} KB`;
          writeToTerminal(`\n[System Workspace] Code reverted to build default.\n`, "system");
        }
      }
    });

    window.addEventListener('DOMContentLoaded', () => {
      lucide.createIcons();
      if (PROJECTS.length > 0) {
        switchProject(PROJECTS[0].id);
      } else {
        filenameEl.textContent = "No Projects Found";
        writeToTerminal("Error: No compatible source code projects detected in repository structure.\n", "error");
      }
    });
  </script>
</body>
</html>
