    // Shell Commands Execution dispatcher
    function executeShellCommand(cmd) {
      if (!cmd) return;

      const args = cmd.split(" ");
      const action = args[0].toLowerCase();

      if (action === "help") {
        term.write("Available system commands:\r\n");
        term.write("  ls               - List project directory structure\r\n");
        term.write("  cat <filename>   - View source file contents\r\n");
        term.write("  run <filename>   - Compile/Interpret any project file\r\n");
        term.write("  clear            - Clear workspace terminal screen\r\n");
      } else if (action === "clear") {
        term.write("\x1b[2J\x1b[H"); // ANSI Clear screen terminal code
      } else if (action === "ls") {
        term.write("Repository project tree:\r\n");
        PROJECTS.forEach(p => {
          term.write(`  \x1b[34m${p.folder}\x1b[0m/${p.filename} (${p.badge})\r\n`);
        });
      } else if (action === "cat") {
        if (args.length < 2) {
          term.write("Usage: cat <filename>\r\n");
          return;
        }
        const file = PROJECTS.find(p => p.filename.toLowerCase() === args[1].toLowerCase());
        if (file) {
          term.write(modifiedCodes[file.id].replace(/\n/g, "\r\n") + "\r\n");
        } else {
          term.write(`File [${args[1]}] not found in repository.\r\n`);
        }
      } else if (action === "run") {
        if (args.length < 2) {
          term.write("Usage: run <filename>\r\n");
          return;
        }
        const file = PROJECTS.find(p => p.filename.toLowerCase() === args[1].toLowerCase());
        if (file) {
          launchProgram(file.id);
        } else {
          term.write(`File [${args[1]}] not found.\r\n`);
        }
      } else {
        term.write(`Command [${action}] unrecognized. Type 'help' for instructions.\r\n`);
      }
    }

    // High-Reliability Stateful Transpiler & Virtual Machine Context (No-crash architecture)
    class UniversalVM {
      constructor(terminalInstance) {
        this.term = terminalInstance;
        this.isWaitingForInput = false;
        this.inputResolver = null;
        this.currentInput = "";
      }

      print(text) {
        const formatted = String(text).replace(/\r?\n/g, "\r\n");
        this.term.write(formatted);
      }

      async input(promptMsg = "") {
        if (promptMsg) {
          this.print(promptMsg);
