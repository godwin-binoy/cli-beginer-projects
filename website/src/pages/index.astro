          <button id="btn-reset" class="flex items-center space-x-1.5 text-xs text-slate-400 hover:text-white bg-slate-900 border border-slate-800 hover:border-slate-700 px-2.5 py-1.5 rounded transition duration-150">
            <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
