        </div>
        
        <!-- Editor Bottom Actions -->
        <div class="p-4 border-t border-slate-800 bg-[#0d111a]/25 flex items-center justify-between flex-wrap gap-2 shrink-0">
          <p class="text-[11px] text-slate-500 font-medium">Auto-saved in-memory. Double-click any file in explorer to run immediately.</p>
          <button id="btn-run" class="flex items-center space-x-2 bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white font-semibold text-xs px-4.5 py-2 rounded transition shadow-[0_0_15px_rgba(16,185,129,0.15)] cursor-pointer">
            <i data-lucide="play" class="w-3.5 h-3.5"></i>
            <span>Run Program</span>
          </button>
        </div>
      </section>

      <!-- Terminal Panel -->
      <section id="panel-terminal" class="hidden lg:flex flex-col overflow-hidden bg-[#030712] h-full">
        <div class="p-4 border-b border-slate-800 bg-[#0d111a]/20 flex items-center justify-between">
          <div class="flex items-center space-x-2">
            <i data-lucide="terminal" class="w-4 h-4 text-emerald-400"></i>
            <span class="text-sm font-semibold font-mono text-slate-300">Terminal Shell</span>
          </div>
          <button id="btn-clear" class="text-xs text-slate-500 hover:text-slate-300 transition duration-150 cursor-pointer">Clear</button>
        </div>

        <div class="flex-1 p-4 overflow-hidden relative">
          <!-- Real wterm integration element -->
          <div id="terminal" class="w-full h-full"></div>
        </div>

        <!-- System Load Statistics bar -->
        <div class="border-t border-slate-800 bg-[#070b12] px-6 py-3 grid grid-cols-3 gap-2 text-[10px] font-mono shrink-0">
          <div>
            <span class="text-slate-500 block">CONTAINER CORE</span>
            <span class="text-slate-300 font-semibold">wterm-WASM V2</span>
          </div>
          <div>
            <span class="text-slate-500 block">LOCAL STATE</span>
            <span class="text-emerald-400 font-semibold flex items-center">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse mr-1.5"></span> SHELL ONLINE
            </span>
          </div>
          <div>
            <span class="text-slate-500 block">SANDBOX ENGINE</span>
            <span class="text-slate-300 font-semibold">Async VM</span>
          </div>
        </div>
      </section>

    </div>
  </div>

  <!-- Passive context transporter element -->
  <div id="projects-data" data-projects={JSON.stringify(projectsList)} class="hidden"></div>

  <!-- Load client libraries -->
  <script>
    import { WTerm } from "@wterm/dom";
    import "@wterm/dom/css";
    import { createIcons, Terminal, Code2, Folder, FolderOpen, RefreshCw, Play, Trash2, Smartphone, Monitor, ChevronDown, FileCode, Coffee, FileText, Github } from "lucide";

    // Initialize UI Icons
    createIcons({
      icons: {
        Terminal,
        Code2,
        Folder,
        FolderOpen,
        RefreshCw,
        Play,
        Trash2,
        Smartphone,
        Monitor,
        ChevronDown,
        FileCode,
        Coffee,
        FileText,
        Github
      }
    });

    const PROJECTS = JSON.parse(document.getElementById("projects-data").getAttribute("data-projects"));
    let activeProjectId = PROJECTS.length > 0 ? PROJECTS[0].id : null;
    let editorInstance = null;
    const modifiedCodes = {};
    const collapsedFolders = {};

    PROJECTS.forEach(p => {
      modifiedCodes[p.id] = p.code;
    });

    // Mobile tabs handler
    const tabExplorer = document.getElementById("tab-btn-explorer");
    const tabEditor = document.getElementById("tab-btn-editor");
    const tabTerminal = document.getElementById("tab-btn-terminal");

    const sidebarExplorer = document.getElementById("sidebar-explorer");
    const panelEditor = document.getElementById("panel-editor");
    const panelTerminal = document.getElementById("panel-terminal");

    function switchMobileTab(tab) {
      // Hide all panels on mobile
      sidebarExplorer.classList.add("hidden");
      panelEditor.classList.add("hidden");
      panelTerminal.classList.add("hidden");

      // Reset tab button borders/text
      tabExplorer.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5";
      tabEditor.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5";
      tabTerminal.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-transparent text-slate-400 flex items-center justify-center gap-1.5";

      if (tab === "explorer") {
        sidebarExplorer.classList.remove("hidden");
        tabExplorer.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5";
      } else if (tab === "editor") {
        panelEditor.classList.remove("hidden");
        tabEditor.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5";
        if (editorInstance) {
          setTimeout(() => editorInstance.layout(), 50);
        }
      } else if (tab === "terminal") {
        panelTerminal.classList.remove("hidden");
        tabTerminal.className = "flex-1 py-3 text-xs font-semibold text-center border-b-2 border-indigo-500 text-white flex items-center justify-center gap-1.5";
      }
    }

    tabExplorer.addEventListener("click", () => switchMobileTab("explorer"));
    tabEditor.addEventListener("click", () => switchMobileTab("editor"));
    tabTerminal.addEventListener("click", () => switchMobileTab("terminal"));

    // Set initial display configuration
    if (window.innerWidth < 1024) {
      switchMobileTab("explorer");
    } else {
      sidebarExplorer.classList.remove("hidden");
      panelEditor.classList.remove("hidden");
      panelTerminal.classList.remove("hidden");
    }

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) {
        sidebarExplorer.classList.remove("hidden");
        panelEditor.classList.remove("hidden");
        panelTerminal.classList.remove("hidden");
      } else {
        switchMobileTab("explorer");
      }
    });

    // Render Redesigned Repository Map/Explorer
    const fileSearch = document.getElementById("file-search");
    function renderExplorer(filter = "") {
      const listEl = document.getElementById("project-list");
      
      // Group files by folder
      const folders = {};
      PROJECTS.forEach(p => {
        if (!folders[p.folder]) {
          folders[p.folder] = [];
        }
        folders[p.folder].push(p);
      });

      let html = "";
      for (const [folderName, files] of Object.entries(folders)) {
        // Filter files inside folders
        const filteredFiles = files.filter(f => f.filename.toLowerCase().includes(filter.toLowerCase()) || folderName.toLowerCase().includes(filter.toLowerCase()));
        if (filteredFiles.length === 0) continue;

        const isCollapsed = collapsedFolders[folderName];
        const chevronClass = isCollapsed ? "-rotate-90" : "";
        const contentsClass = isCollapsed ? "hidden" : "block";
        const folderIcon = isCollapsed ? "folder" : "folder-open";

        html += `
          <div class="folder-group mb-2" data-folder="${folderName}">
            <button class="folder-header w-full flex items-center justify-between py-1.5 px-2.5 text-slate-300 bg-slate-950/60 hover:bg-slate-900/60 border border-slate-800/40 rounded transition cursor-pointer" data-toggle="${folderName}">
              <div class="flex items-center space-x-2">
                <i data-lucide="${folderIcon}" class="w-4 h-4 text-amber-500 shrink-0"></i>
                <span class="text-[11px] font-semibold font-mono tracking-tight">${folderName}</span>
              </div>
              <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-slate-500 transition-transform duration-200 ${chevronClass}"></i>
            </button>
            <div class="folder-contents pl-3 pr-1 py-1 space-y-1 mt-1 ${contentsClass}">
              ${filteredFiles.map(file => {
                const isActive = file.id === activeProjectId;
                let icon = "file-text";
                let iconColor = "text-slate-400";
                if (file.lang === "python") { icon = "terminal"; iconColor = "text-sky-400"; }
                else if (file.lang === "c") { icon = "file-code"; iconColor = "text-indigo-400"; }
                else if (file.lang === "java") { icon = "coffee"; iconColor = "text-orange-400"; }

                return `
                  <button data-id="${file.id}" class="file-item w-full text-left py-1.5 px-2 rounded transition flex items-center justify-between cursor-pointer ${
                    isActive 
                      ? 'bg-indigo-600/15 border border-indigo-500/30 text-white font-bold' 
                      : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/30 border border-transparent font-medium'
                  }">
                    <div class="flex items-center space-x-1.5 min-w-0">
                      <i data-lucide="${icon}" class="w-3.5 h-3.5 ${iconColor} shrink-0"></i>
                      <span class="text-[11px] font-mono truncate">${file.filename}</span>
                    </div>
                    <span class="text-[8px] font-mono px-1 py-0.5 rounded bg-slate-950 text-slate-500 border border-slate-800/60 uppercase font-semibold shrink-0">${file.badge}</span>
                  </button>
                `;
              }).join('')}
            </div>
          </div>
        `;
      }

      listEl.innerHTML = html;
      createIcons({
        icons: { Folder, FolderOpen, ChevronDown, Terminal, FileCode, Coffee, FileText }
      });

      // Attach fold/collapse listeners
      listEl.querySelectorAll('.folder-header[data-toggle]').forEach(header => {
        header.addEventListener('click', () => {
          const folderName = header.getAttribute('data-toggle');
          collapsedFolders[folderName] = !collapsedFolders[folderName];
          renderExplorer(filter);
        });
      });

      // Attach file click triggers
      listEl.querySelectorAll('.file-item[data-id]').forEach(btn => {
        btn.addEventListener('click', () => {
          switchProject(btn.getAttribute('data-id'));
          if (window.innerWidth < 1024) {
            switchMobileTab("editor");
          }
        });

        // Instant run on double click
        btn.addEventListener('dblclick', () => {
          const id = btn.getAttribute('data-id');
          switchProject(id);
          launchProgram(id);
        });
      });
    }

    fileSearch.addEventListener("input", (e) => {
      renderExplorer(e.target.value);
    });

    // Monaco AMD Load & Config callback
    function loadMonaco(callback) {
      if (window.monaco) {
        callback();
        return;
      }
      if (window.require) {
        require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs' } });
        require(['vs/editor/editor.main'], function () {
          callback();
        });
      } else {
        setTimeout(() => loadMonaco(callback), 50);
      }
    }

    // Interactive Terminal Implementation (wterm Engine)
    let term = null;
    let shellInput = "";
    let isProgramRunning = false;
    let activeVM = null;

    async function initTerminal() {
      term = new WTerm(document.getElementById("terminal"), {
        cols: 80,
        rows: 24,
        autoResize: true,
        cursorBlink: true,
        onData: (data) => {
          if (isProgramRunning) {
            if (activeVM) {
              activeVM.handleKey(data);
            }
            return;
          }

          // Interactive CLI shell
          for (let char of data) {
            if (char === "\r" || char === "\n") {
              term.write("\r\n");
              executeShellCommand(shellInput.trim());
              shellInput = "";
              if (!isProgramRunning) {
                term.write("guest@cli-playground:~$ ");
              }
            } else if (char === "\u007F" || char === "\b") { // Backspace
              if (shellInput.length > 0) {
                shellInput = shellInput.slice(0, -1);
                term.write("\b \b");
              }
            } else {
              shellInput += char;
              term.write(char);
            }
          }
        }
      });

      await term.init();
      term.write("CLI Sandbox Interactive Shell [wterm v2.0]\r\n");
      term.write("Type 'help' to display list of commands.\r\n\r\n");
      term.write("guest@cli-playground:~$ ");
    }

    // Shell Commands Execution dispatcher
    function executeShellCommand(cmd) {
      if (!cmd) return;

      const args = cmd.split(" ");
      const action = args[0].toLowerCase();

      if (action === "help") {
        term.write("Available system commands:\r\n");
        term.write("  ls               - List project directory structure\r\n");
        term.write("  cat <filename>   - View source file contents\r\n");
        term.write("  run <filename>   - Compile/Interpret any project file\r\n");
        term.write("  clear            - Clear workspace terminal screen\r\n");
      } else if (action === "clear") {
        term.write("\x1b[2J\x1b[H"); // ANSI Clear screen terminal code
      } else if (action === "ls") {
        term.write("Repository project tree:\r\n");
        PROJECTS.forEach(p => {
          term.write(`  \x1b[34m${p.folder}\x1b[0m/${p.filename} (${p.badge})\r\n`);
        });
      } else if (action === "cat") {
        if (args.length < 2) {
          term.write("Usage: cat <filename>\r\n");
          return;
        }
        const file = PROJECTS.find(p => p.filename.toLowerCase() === args[1].toLowerCase());
        if (file) {
          term.write(modifiedCodes[file.id].replace(/\n/g, "\r\n") + "\r\n");
        } else {
          term.write(`File [${args[1]}] not found in repository.\r\n`);
        }
      } else if (action === "run") {
        if (args.length < 2) {
          term.write("Usage: run <filename>\r\n");
          return;
        }
        const file = PROJECTS.find(p => p.filename.toLowerCase() === args[1].toLowerCase());
        if (file) {
          launchProgram(file.id);
        } else {
          term.write(`File [${args[1]}] not found.\r\n`);
        }
      } else {
        term.write(`Command [${action}] unrecognized. Type 'help' for instructions.\r\n`);
      }
    }

    // High-Reliability Stateful Transpiler & Virtual Machine Context (No-crash architecture)
    class UniversalVM {
      constructor(terminalInstance) {
        this.term = terminalInstance;
        this.isWaitingForInput = false;
        this.inputResolver = null;
        this.currentInput = "";
      }

      print(text) {
        const formatted = String(text).replace(/\r?\n/g, "\r\n");
        this.term.write(formatted);
      }

      async input(promptMsg = "") {
        if (promptMsg) {
          this.print(promptMsg);
        }
        this.isWaitingForInput = true;
        this.currentInput = "";
        return new Promise((resolve) => {
          this.inputResolver = resolve;
        });
      }

      handleKey(key) {
        if (!this.isWaitingForInput) return;

        if (key === "\r" || key === "\n") {
          this.print("\r\n");
          const result = this.currentInput;
          this.isWaitingForInput = false;
          this.currentInput = "";
          if (this.inputResolver) {
            this.inputResolver(result);
          }
        } else if (key === "\u007F" || key === "\b") { // Backspace
          if (this.currentInput.length > 0) {
            this.currentInput = this.currentInput.slice(0, -1);
            this.term.write("\b \b");
          }
        } else {
          this.currentInput += key;
          this.term.write(key);
        }
      }

      transpilePython(code) {
        const lines = code.split('\n');
        let js = `
          const random = {
            randint: (a, b) => Math.floor(Math.random() * (b - a + 1)) + a,
            sample: (chars, len) => {
              let res = '';
              for (let i = 0; i < len; i++) {
                res += chars[Math.floor(Math.random() * chars.length)];
              }
              return res.split('');
            }
          };
          const math = {
            log: (x, base = Math.E) => Math.log(x) / Math.log(base),
            log2: (x) => Math.log2(x)
          };
          const len = (x) => (x ? x.length : 0);
          const round = (x) => Math.round(x);
          const int = (x) => {
            let v = parseInt(x);
            if (isNaN(v)) throw new Error("ValueError");
            return v;
          };
          const str = (x) => String(x);
          const exit = () => { throw new Error('EXIT_CALL'); };
          
          async function run() {
        `;

        // Robust scoping scanner to declare variables at the top of the closure
        let vars = new Set();
        for (let line of lines) {
          let trimmed = line.trim();
          let m = trimmed.match(/^([a-zA-Z_][a-zA-Z0-9_]*)\s*=[^=]/);
          if (m) {
            vars.add(m[1]);
          }
        }
        let preDeclarations = Array.from(vars).map(v => `let ${v};`).join('\n');
        js += preDeclarations + "\n";

        let indentStack = [0];

        for (let i = 0; i < lines.length; i++) {
          let line = lines[i];
          let trimmed = line.trim();

          // Safely skip empty space, comments, and raw python module imports
          if (!trimmed || trimmed.startsWith('#') || trimmed.startsWith('import ') || trimmed.startsWith('from ') || trimmed.startsWith('global ')) {
            continue;
          }

          let spaces = line.match(/^([ \t]*)/)[0];
          let indent = spaces.replace(/\t/g, '    ').length;

          // Align structural indent boundaries statefully
          let endsWithColon = trimmed.endsWith(':');
          let stmt = endsWithColon ? trimmed.slice(0, -1).trim() : trimmed;
          let isExcept = stmt.startsWith('except');

          while (indent < indentStack[indentStack.length - 1]) {
            let popped = indentStack.pop();
            if (!isExcept || indentStack[indentStack.length - 1] > indent) {
              js += ' '.repeat(popped) + '}\n';
            }
          }

          if (endsWithColon) {
            if (stmt.startsWith('while ')) {
              let cond = stmt.substring(6).trim();
              if (cond === 'True') cond = 'true';
              js += `while (${cond}) {\n`;
              indentStack.push(indent + 4);
            } else if (stmt.startsWith('if ')) {
              let cond = stmt.substring(3).trim();
              cond = cond.replace(/\band\b/g, '&&').replace(/\bor\b/g, '||').replace(/\bnot\b/g, '!');
              js += `if (${cond}) {\n`;
              indentStack.push(indent + 4);
            } else if (stmt.startsWith('elif ')) {
              let cond = stmt.substring(5).trim();
              cond = cond.replace(/\band\b/g, '&&').replace(/\bor\b/g, '||').replace(/\bnot\b/g, '!');
              js += `} else if (${cond}) {\n`;
              indentStack.push(indent + 4);
            } else if (stmt === 'else') {
              js += `} else {\n`;
              indentStack.push(indent + 4);
            } else if (stmt === 'try') {
              js += `try {\n`;
              indentStack.push(indent + 4);
            } else if (stmt.startsWith('except')) {
              js += `} catch (err) {\n`;
              indentStack.push(indent + 4);
            } else if (stmt.startsWith('def ')) {
              let sig = stmt.substring(4).trim();
              js += `async function ${sig} {\n`;
              indentStack.push(indent + 4);
            } else if (stmt.startsWith('for ') && stmt.includes(' in range(')) {
              let loopParts = stmt.substring(4).split(' in range(');
              let varName = loopParts[0].trim();
              let rangeArgs = loopParts[1].slice(0, -1).split(',');
              let start = "0", end = "0", step = "1";
              if (rangeArgs.length === 1) {
                end = rangeArgs[0].trim();
              } else if (rangeArgs.length === 2) {
                start = rangeArgs[0].trim();
                end = rangeArgs[1].trim();
              } else if (rangeArgs.length === 3) {
                start = rangeArgs[0].trim();
                end = rangeArgs[1].trim();
                step = rangeArgs[2].trim();
              }
              js += `for (let ${varName} = ${start}; ${varName} < ${end}; ${varName} += ${step}) {\n`;
              indentStack.push(indent + 4);
            }
          } else {
            if (stmt.startsWith('print(')) {
              let inner = stmt.substring(6, stmt.length - 1).trim();
              if (inner.startsWith('f"') || inner.startsWith("f'")) {
                let content = inner.substring(2, inner.length - 1);
                content = content.replace(/\{([^}]+)\}/g, '${$1}');
                js += `print(\`${content}\\n\`);\n`;
              } else {
                js += `print(${inner} + '\\n');\n`;
              }
            } else if (stmt.startsWith('input(')) {
              let inner = stmt.substring(6, stmt.length - 1).trim();
              js += `await input(${inner});\n`;
            } else {
              // Convert .join syntax representation dynamically: e.g. "''.join(random.sample(...))" to "random.sample(...).join('')"
              stmt = stmt.replace(/['"](.*)['"]\.join\((.*)\)/g, "($2).join('$1')");
              js += `${stmt};\n`;
            }
          }
        }

        while (indentStack.length > 1) {
          js += '}\n';
          indentStack.pop();
        }

        js += `
          }
          await run();
        `;
        return js;
      }

      transpileC(code) {
        const lines = code.split('\n');
        let jsCode = `async function run() {\n`;
        let vars = new Set();

        // Scan declarations inside main loop boundary
        for (let line of lines) {
          let trimmed = line.trim();
          let m = trimmed.match(/^(int|float|double|char|bool)\s+([a-zA-Z_][a-zA-Z0-9_]*)/);
          if (m) {
            vars.add(m[2]);
          }
        }

        let preDeclarations = Array.from(vars).map(v => `let ${v} = 0;`).join('\n');
        jsCode += preDeclarations + "\n";

        for (let line of lines) {
          let trimmed = line.trim();
          if (!trimmed || trimmed.startsWith('#include') || trimmed.startsWith('int main') || trimmed.startsWith('return 0') || trimmed === '}' || trimmed === '{') {
            continue;
          }

          let statement = trimmed;
          if (trimmed.startsWith('printf(')) {
            let inner = trimmed.substring(7, trimmed.indexOf(');')).trim();
            if (inner.includes(',')) {
              let commaIndex = inner.indexOf(',');
              let formatStr = inner.substring(0, commaIndex).trim();
              formatStr = formatStr.substring(1, formatStr.length - 1);
              let varsStr = inner.substring(commaIndex + 1);
              let varsList = varsStr.split(',').map(v => v.trim());
              let i = 0;
              let formatted = formatStr.replace(/%d/g, () => `\${${varsList[i++]}}`);
              statement = `print(\`${formatted}\`);`;
            } else {
              let text = inner.substring(1, inner.length - 1);
              statement = `print(\`${text}\`);`;
            }
          } else if (trimmed.startsWith('scanf(')) {
            let inner = trimmed.substring(6, trimmed.indexOf(');'));
            let parts = inner.split(',');
            let varName = parts[1].replace('&', '').trim();
            statement = `${varName} = parseInt(await input(""));`;
          } else {
            statement = statement.replace(/^(int|float|double|char|bool)\s+/g, '');
            statement = statement.replace(/for\s*\(int\s+/g, 'for (let ');
          }

          jsCode += "    " + statement + "\n";
        }

        jsCode += `\n}\nawait run();`;
        return jsCode;
      }

      transpileJava(code) {
        const lines = code.split('\n');
        let jsCode = `
          const check = (value) => {
            if (!value) return false;
            for (let c of String(value)) {
              if (c < '0' || c > '9') return false;
            }
            return true;
          };
          
          const user_input = async () => {
            return await input("");
          };

          const Integer = {
            parseInt: (v) => parseInt(v)
          };

          const Character = {
            isDigit: (c) => {
              return c >= '0' && c <= '9';
            }
          };

          async function run() {
        `;

        let vars = new Set();
        for (let line of lines) {
          let trimmed = line.trim();
          let m = trimmed.match(/^(int|String|Scanner|boolean|char)\s+([a-zA-Z_][a-zA-Z0-9_]*)/);
          if (m) {
            if (m[2] !== 'main' && m[2] !== 'check' && m[2] !== 'user_input') {
              vars.add(m[2]);
            }
          }
        }

        let preDeclarations = Array.from(vars).map(v => `let ${v};`).join('\n');
        jsCode += "      " + preDeclarations + "\n";

        let inMain = false;
        for (let line of lines) {
          let trimmed = line.trim();
          
          if (trimmed.includes('public static void main') || trimmed.includes('public class')) {
            inMain = true;
            continue;
          }
          
          if (trimmed.includes('public static String user_input') || trimmed.includes('public static boolean check')) {
            inMain = false;
            continue;
          }

          if (!inMain) continue;

          let statement = trimmed;
          if (trimmed.startsWith('System.out.println(')) {
            let inner = trimmed.substring(19, trimmed.indexOf(');'));
            statement = `print(${inner} + "\\n");`;
          } else if (trimmed.startsWith('System.out.print(')) {
            let inner = trimmed.substring(17, trimmed.indexOf(');'));
            statement = `print(${inner});`;
          } else {
            statement = statement.replace(/^(int|String|Scanner|boolean|char)\s+/g, '');
            statement = statement.replace(/for\s*\(\s*char\s+([a-zA-Z_][a-zA-Z0-9_]*)\s*:\s*(.+)\.toCharArray\(\)\s*\)/g, 'for (let $1 of $2)');
            statement = statement.replace(/for\s*\(int\s+/g, 'for (let ');
            statement = statement.replace(/\buser_input\(\)/g, 'await user_input()');
          }

          jsCode += "      " + statement + "\n";
        }

        jsCode += `
          }
          await run();
        `;
        return jsCode;
      }

      async execute(code, lang) {
        let jsSource = "";
        try {
          if (lang === "python") {
            jsSource = this.transpilePython(code);
          } else if (lang === "c") {
            jsSource = this.transpileC(code);
          } else if (lang === "java") {
            jsSource = this.transpileJava(code);
          } else {
            throw new Error("Unsupported target engine: " + lang);
          }

          const context = {
            print: this.print.bind(this),
            input: this.input.bind(this)
          };

          const runner = new Function("context", `
            with(context) {
              return (async () => {
                ${jsSource}
              })();
            }
          `);

          await runner(context);
        } catch (err) {
          if (err.message !== 'EXIT_CALL') {
            this.print(`\r\n[VM EXCEPTION] ${err.message}\r\n`);
          }
        }
      }
    }

    // Launch Program Runner wrapper
    async function launchProgram(id) {
      const p = PROJECTS.find(proj => proj.id === id);
      if (!p) return;

      if (isProgramRunning) {
        term.write("\r\n[Alert] A program is already executing. Kill process first.\r\n");
        return;
      }

      if (p.lang !== "python" && p.lang !== "c" && p.lang !== "java") {
        term.write(`\r\n\x1b[31m[Execution Error] Language target [${p.badge}] cannot be compiled inside this native web sandbox. Please select a C, Java, or Python file.\x1b[0m\r\n`);
        term.write("guest@cli-playground:~$ ");
        return;
      }

      isProgramRunning = true;
      activeVM = new UniversalVM(term);

      if (window.innerWidth < 1024) {
        switchMobileTab("terminal");
      }

      term.write(`\x1b[32m[Executing ${p.filename} via VM...]\x1b[0m\r\n`);
      const codeToRun = editorInstance ? editorInstance.getValue() : modifiedCodes[id];
      
      await activeVM.execute(codeToRun, p.lang);
      
      term.write(`\r\n\x1b[32m[Program finished execution]\x1b[0m\r\n`);
      isProgramRunning = false;
      activeVM = null;
      term.write("guest@cli-playground:~$ ");
    }

    // Workstation switch project project loading
    function switchProject(id) {
      if (isProgramRunning) {
        term.write("\r\n[Alert] Cannot switch workspace while program is running.\r\n");
        return;
      }

      if (editorInstance && activeProjectId) {
        modifiedCodes[activeProjectId] = editorInstance.getValue();
      }

      activeProjectId = id;
      const p = PROJECTS.find(proj => proj.id === id);
      if (!p) return;

      document.getElementById("editor-filename").textContent = p.file;
      document.getElementById("editor-badge").textContent = p.badge;

      renderExplorer(fileSearch.value);

      loadMonaco(() => {
        let langMap = p.lang;
        if (p.lang === 'c') langMap = 'cpp';
        else if (p.lang === 'plaintext') langMap = 'plaintext';
        
        if (editorInstance) {
          editorInstance.setValue(modifiedCodes[id]);
          monaco.editor.setModelLanguage(editorInstance.getModel(), langMap);
        } else {
          editorInstance = monaco.editor.create(document.getElementById("editor-container"), {
            value: modifiedCodes[id],
            language: langMap,
            theme: 'vs-dark',
            automaticLayout: true,
            fontFamily: 'Fira Code, monospace',
            fontSize: 14,
            minimap: { enabled: false },
            scrollbar: {
              vertical: 'visible',
              horizontal: 'visible'
            }
          });
        }
      });
    }

    // Toolbar Action Listeners
    document.getElementById("btn-run").addEventListener("click", () => {
      if (activeProjectId) {
        launchProgram(activeProjectId);
      }
    });

    document.getElementById("btn-reset").addEventListener("click", () => {
      if (confirm("Revert file to origin repository version?")) {
        const p = PROJECTS.find(proj => proj.id === activeProjectId);
        if (p) {
          modifiedCodes[activeProjectId] = p.code;
          if (editorInstance) {
            editorInstance.setValue(p.code);
          }
        }
      }
    });

    document.getElementById("btn-clear").addEventListener("click", () => {
      term.write("\x1b[2J\x1b[H");
    });

    // Lifecycle Init
    window.addEventListener("DOMContentLoaded", () => {
      renderExplorer();
      initTerminal();
      if (PROJECTS.length > 0) {
        switchProject(PROJECTS[0].id);
      }
    });
  </script>
</body>
