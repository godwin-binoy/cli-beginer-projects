import fs from 'fs';
import path from 'path';
import '../styles/global.css';

function getRootDir() {
  const cwd = process.cwd();
  if (fs.existsSync(path.join(cwd, 'Character-Counter'))) {
    return cwd;
  }
  const parentPath = path.resolve(cwd, '..');
  if (fs.existsSync(path.join(parentPath, 'Character-Counter'))) {
    return parentPath;
  }
  let dir = cwd;
  for (let i = 0; i < 6; i++) {
    if (fs.existsSync(path.join(dir, 'Character-Counter'))) {
      return dir;
    }
    const parent = path.dirname(dir);
    if (parent === dir) break;
    dir = parent;
  }
  return cwd;
}

const rootDir = getRootDir();

function getProjects() {
  const projects = [];
  if (!fs.existsSync(rootDir)) {
    return [];
  }
  
  const items = fs.readdirSync(rootDir);
  const ignoreList = ['.git', '.github', 'website', 'node_modules', '.astro'];
  
  for (const item of items) {
    if (ignoreList.includes(item)) continue;
    const itemPath = path.join(rootDir, item);
    const stat = fs.statSync(itemPath);
    
    if (stat.isDirectory()) {
      const files = fs.readdirSync(itemPath);
      for (const file of files) {
        const filePath = path.join(itemPath, file);
        const fileStat = fs.statSync(filePath);
        if (fileStat.isFile()) {
          const ext = path.extname(file).toLowerCase();
          let lang = '';
          let badge = '';
          if (ext === '.py') { lang = 'python'; badge = 'Python'; }
          else if (ext === '.c') { lang = 'c'; badge = 'C'; }
          else if (ext === '.java') { lang = 'java'; badge = 'Java'; }
          else if (ext === '.txt') { lang = 'plaintext'; badge = 'Text'; }
          else if (ext === '.json') { lang = 'json'; badge = 'JSON'; }
          else if (ext === '.md') { lang = 'markdown'; badge = 'MD'; }
          else { lang = 'plaintext'; badge = ext.toUpperCase().replace('.', ''); }
          
          const code = fs.readFileSync(filePath, 'utf-8');
          const id = `${item.toLowerCase()}-${file.toLowerCase().replace(/[^a-z0-9]/g, '-')}`;
          const title = item.replace(/-/g, ' ');
          const description = `Repository file: ${item}/${file}.`;
          
          projects.push({
            id,
            title: `${title} (${file})`,
            folder: item,
            filename: file,
            lang,
            badge,
            file: `${item}/${file}`,
            description,
            code
          });
        }
      }
    }
  }
  return projects.sort((a, b) => a.title.localeCompare(b.title));
}

const projectsList = getProjects();
